# URL Base de la API (Backend)
VITE_API_BASE="https://api.midominio.com"

# Cloudflare Turnstile Site Key (Opcional - Protección Anti-Bot)
# VITE_TURNSTILE_SITE_KEY="0x4..."

# Cloudinary — subida de foto de perfil (unsigned upload).
# Crear cuenta gratis en cloudinary.com, copiar el "Cloud name" y crear un
# Upload Preset en modo "Unsigned" (Settings → Upload → Add upload preset).
# VITE_CLOUDINARY_CLOUD_NAME="tu_cloud_name"
# VITE_CLOUDINARY_UPLOAD_PRESET="tu_unsigned_preset"
