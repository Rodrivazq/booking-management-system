# --- 1. Dependencies (The heavy libraries) ---
node_modules/

# --- 2. Security (NEVER remove these) ---
.env
.env.local
.env.test.local
.env.production.local
# Cualquier variante/backup de env (staging, *.bak) nunca debe subirse,
# excepto los .env.example que sí son plantillas públicas.
.env.*
!.env.example
*.bak

# --- 3. Database & Prisma (The Generated Code) ---
# Ignore the actual data database
*/data/db.json
# Ignore the code generated by Prisma (restore this line!)
backend/src/generated/prisma/

# --- 4. Build Outputs (The "Cooked" App) ---
# Ignore the 'dist' folder in ANY folder (frontend or backend)
dist/
build/

# --- 5. Logs (The Error Diaries) ---
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- 6. Operating System Junk (The Invisible Trash) ---
.DS_Store
Thumbs.db

# --- 7. Editor Settings (Personal Preferences) ---
.vscode/
# Exception: Share recommended extensions with the team
!.vscode/extensions.json
.idea/
*.sln
.cursorrules

# --- 8. Backups & Database Dumps ---
backups/
*.dump
*.sql
*.backup

# --- 9. Demo seed manifest (artefacto local de rollback, no commitear) ---
backend/.demo-manifest.json
backend/.demo-manifest.json.done
