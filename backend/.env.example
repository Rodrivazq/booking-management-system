# Base de Datos
DATABASE_URL="postgresql://usuario:password@host:puerto/nombre_base_datos"

# Seguridad
JWT_SECRET="TU_SECRETO_AQUI_DEBE_SER_LARGO_Y_SEGURO"

# URL del Frontend (Para correos y CORS)
FRONTEND_URL="https://midominio.com"

# Entorno
NODE_ENV="production"
TZ="America/Montevideo" # Asegurar timezone correcto

# Configuración de Correos (Opción 1: Resend)
RESEND_API_KEY="re_tus_credenciales_aqui"

# Configuración de Correos (Opción 2: SMTP Clásico)
# SMTP_HOST="smtp.tudominio.com"
# SMTP_PORT="587"
# SMTP_USER="usuario@tudominio.com"
# SMTP_PASS="tu_contraseña"
# SMTP_SECURE="false"
# SMTP_FROM="Nombre <usuario@tudominio.com>"

# Cloudflare Turnstile (Opcional - Protección Anti-Bot)
# TURNSTILE_SECRET_KEY="0x4..."
