generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String
  passwordHash String
  role         String   @default("user")
  funcNumber   String   @unique
  documentId   String?  @unique
  phoneNumber  String?
  photoUrl     String?
  preferences  String?
  // Lunes (YYYY-MM-DD) de la semana en curso habilitada por un admin para que
  // este usuario pueda reservar fuera de la ventana normal (alta a mitad de
  // semana). Se "vence" solo: deja de aplicar cuando cambia la semana.
  reservationOverrideWeek String?
  // Momento en que el usuario aceptó los Términos y la Política de Privacidad
  // (evidencia de consentimiento, Ley 18.331).
  acceptedTermsAt DateTime?
  isEmailVerified Boolean @default(false)
  verificationToken String? @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  reservations  Reservation[]
  passwordResets PasswordReset[]
  dishRatings    DishRating[]
}

model Settings {
  id                  Int     @id @default(1)
  companyName         String  @default("Sistema de Reservas Corporativo")
  logoUrl             String?
  primaryColor        String? @default("#16a34a")
  secondaryColor      String? @default("#1e293b")
  deadlineDay         Int     @default(4)
  deadlineTime        String  @default("23:59")
  supportEmail        String?
  supportPhone        String?
  welcomeTitle        String?
  welcomeMessage      String?
  loginBackgroundImage String?
  // Difuminado del fondo del login: desenfoque (px), oscurecido (%) y color del tinte.
  loginBackgroundBlur Int     @default(0)
  loginBackgroundDim  Int     @default(55)
  loginBackgroundColor String? @default("#1e293b")
  maintenanceMode     Boolean @default(false)
  announcementMessage String?
  announcementType    String? @default("info")
}

model WeeklyMenu {
  id             String  @id @default(uuid())
  weekStart      String  @unique
  days           String
  breadAvailable Boolean @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Reservation {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weekStart   String
  timeSlot    String
  selections  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  dishRatings DishRating[]

  @@unique([userId, weekStart])
}


model PasswordReset {
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model DishRating {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reservationId String
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  weekStart     String
  day           String
  itemType      String   // "meal" | "dessert"
  itemName      String
  rating        String   // "liked" | "neutral" | "disliked"
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, weekStart, day, itemType, itemName])
}
